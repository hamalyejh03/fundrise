# ============================================================
# FundRise — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── DATABASE ─────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/fundrise_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ─── JWT ──────────────────────────────────────────────────
# Must be at least 32 random characters. Use: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-string-at-least-256-bits
JWT_EXPIRATION=86400000   # 24 hours in milliseconds

# ─── STRIPE ───────────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get webhook secret from: https://dashboard.stripe.com/webhooks
# Local dev: use `stripe listen --forward-to localhost:8080/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── CLOUDINARY ───────────────────────────────────────────
# Get keys from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── FRONTEND (React, prefix with REACT_APP_) ─────────────
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── LOCAL FILE STORAGE (fallback when Cloudinary is not configured) ──────
# Used in development so images display without a Cloudinary account.
# app.uploads.dir: disk path where uploaded images are stored
# app.uploads.base-url: base URL the frontend uses to load those images
UPLOADS_DIR=uploads
APP_BASE_URL=http://localhost:8080
